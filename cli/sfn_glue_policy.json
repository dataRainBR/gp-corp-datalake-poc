{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GlueJobsSync",
      "Effect": "Allow",
      "Action": [
        "glue:StartJobRun",
        "glue:GetJobRun",
        "glue:GetJobRuns",
        "glue:BatchStopJobRun"
      ],
      "Resource": [
        "arn:aws:glue:us-east-1:892748149777:job/gpcorp-*"
      ]
    },
    {
      "Sid": "GlueCrawler",
      "Effect": "Allow",
      "Action": [
        "glue:StartCrawler",
        "glue:GetCrawler"
      ],
      "Resource": [
        "arn:aws:glue:us-east-1:892748149777:crawler/gpcorp-*"
      ]
    },
    {
      "Sid": "SNSPublish",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "arn:aws:sns:us-east-1:892748149777:gpcorp-glue-pipeline-alerts"
    },
    {
      "Sid": "EventsForSync",
      "Effect": "Allow",
      "Action": [
        "events:PutTargets",
        "events:PutRule",
        "events:DescribeRule"
      ],
      "Resource": "arn:aws:events:us-east-1:892748149777:rule/StepFunctionsGetEventsForGlueJobRunsRule"
    }
  ]
}
